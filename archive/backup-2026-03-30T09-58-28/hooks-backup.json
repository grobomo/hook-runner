{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/hooks/run-sessionstart.js\"",
          "timeout": 5
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/hooks/run-stop.js\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/hooks/run-posttooluse.js\"",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/hooks/run-posttooluse.js\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/hooks/run-pretooluse.js\"",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/hooks/run-pretooluse.js\"",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/hooks/run-pretooluse.js\"",
          "timeout": 5
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/hooks/run-userpromptsubmit.js\"",
          "timeout": 5
        }
      ]
    }
  ]
}